{
  "version": "1.0",
  "projections": {
    "todo-server-sdk": {
      "plugins": {
        "rust-server-codegen": {
          "runtimeConfig": {
            "relativePath": "../smithy-rs/rust-runtime"
          },
          "codegen": {},
          "service": "common#Listeria",
          "module": "todo-server-sdk",
          "moduleVersion": "0.1.0",
          "moduleDescription": "Rust server SDK for todo app",
          "moduleAuthors": [
            "whlapinel@gmail.com"
          ]
        }
      }
    },
    "todo-client": {
      "plugins": {
        "rust-client-codegen": {
          "runtimeConfig": {
            "relativePath": "../smithy-rs/rust-runtime"
          },
          "codegen": {},
          "service": "common#Listeria",
          "module": "todo-client",
          "moduleVersion": "0.1.0",
          "moduleDescription": "Rust client for todo app",
          "moduleAuthors": [
            "whlapinel@gmail.com"
          ]
        }
      }
    }
  }
}